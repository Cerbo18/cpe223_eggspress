<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cpe223.group8.eggspress.controllers.InventoryController"
      prefHeight="600.0" prefWidth="800.0"
      styleClass="view-root-container">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
        <URL value="@../css/inventory/inventory.css" />
        <URL value="@../css/inventory/light.css" />
    </stylesheets>

    <VBox spacing="20.0" VBox.vgrow="ALWAYS" styleClass="view-content-pane">
        <padding>
            <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
        </padding>

        <VBox spacing="6.0">
            <Label text="Inventory Management" styleClass="view-title"/>
            <Label text="Track feed levels, water stock, supplements, and evaluate monthly consumption needs based on flock sizes." styleClass="view-desc"/>
        </VBox>

        <TabPane fx:id="inventoryTabPane" VBox.vgrow="ALWAYS" styleClass="modern-tab-pane" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <!-- Tab 1: Current Stock & Controls -->
                <Tab text="Current Stock &amp; Controls" styleClass="modern-tab">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-padding: 0;">
                            <content>
                                <VBox spacing="20.0" style="-fx-padding: 20px 8px 20px 0px;">
                                    <!-- Inventory List Card -->
                                    <VBox spacing="16.0" styleClass="content-card" minHeight="450.0" VBox.vgrow="ALWAYS">
                                        <!-- Header Row with Add Button -->
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <Label text="Current Farm Inventory" styleClass="card-title" HBox.hgrow="ALWAYS"/>
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Button fx:id="addItemBtn" text="Add Item" onAction="#handleOpenCreateItemModal" styleClass="button-primary" prefHeight="36.0" prefWidth="120.0"/>
                                            </children>
                                        </HBox>
                                        
                                        <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS" minHeight="360.0">
                                            <columns>
                                                <TableColumn fx:id="idColumn" text="ID" prefWidth="80.0"/>
                                                <TableColumn fx:id="nameColumn" text="Name" prefWidth="200.0"/>
                                                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120.0"/>
                                                <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="120.0"/>
                                                <TableColumn fx:id="unitColumn" text="Unit" prefWidth="100.0"/>
                                                <TableColumn fx:id="actionColumn" text="Actions" prefWidth="160.0" styleClass="centered-column"/>
                                            </columns>
                                            <columnResizePolicy>
                                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                            </columnResizePolicy>
                                        </TableView>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- Tab 2: Monthly Consumption Planner -->
                <Tab text="Monthly Consumption Planner" styleClass="modern-tab">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-padding: 0;">
                            <content>
                                <VBox spacing="20.0" style="-fx-padding: 20px 8px 20px 0px;">
                                    <!-- Selection & Estimator Controls Card -->
                                    <VBox spacing="16.0" styleClass="content-card">
                                        <Label text="Monthly Supply Consumption Estimator" styleClass="card-title"/>
                                        <GridPane hgap="20.0" vgap="16.0">
                                            <columnConstraints>
                                                <ColumnConstraints percentWidth="30.0"/>
                                                <ColumnConstraints percentWidth="20.0"/>
                                                <ColumnConstraints percentWidth="25.0"/>
                                                <ColumnConstraints percentWidth="25.0"/>
                                            </columnConstraints>
                                            <children>
                                                <!-- Month Selection -->
                                                <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                                    <Label text="Target Month" styleClass="form-label"/>
                                                    <ComboBox fx:id="plannerMonthComboBox" maxWidth="Infinity" styleClass="combo-box-modern"/>
                                                </VBox>
                                                
                                                <!-- Year Input -->
                                                <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                                    <Label text="Target Year" styleClass="form-label"/>
                                                    <TextField fx:id="plannerYearField" styleClass="text-input-modern" promptText="Year"/>
                                                </VBox>
                                                
                                                <!-- Total Flock Readonly Stat -->
                                                <VBox spacing="6.0" styleClass="estimator-stat-box" GridPane.columnIndex="2" GridPane.rowIndex="0" alignment="CENTER_LEFT">
                                                    <Label text="ACTIVE FLOCK SIZE" styleClass="form-label"/>
                                                    <Label fx:id="plannerFlockLabel" text="0 Birds" styleClass="stat-value" style="-fx-font-size: 20px;"/>
                                                </VBox>
                                            </children>
                                        </GridPane>
                                        
                                        <Region styleClass="modern-divider" style="-fx-min-height: 1px; -fx-pref-height: 1px; -fx-max-height: 1px; -fx-background-color: -fx-separator-color; -fx-margin: 8px 0;"/>
                                        
                                        <!-- Estimates and Live Sufficiency Status Cards -->
                                        <HBox spacing="20.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                            <children>
                                                <!-- Feed Estimate Card -->
                                                <VBox styleClass="estimator-badge-card" HBox.hgrow="ALWAYS" spacing="8.0" style="-fx-padding: 12px; -fx-border-color: -fx-input-border-color; -fx-border-width: 1px; -fx-border-radius: 8px; -fx-background-radius: 8px;">
                                                    <Label text="ESTIMATED FEED REQUIREMENT (30 DAYS)" styleClass="stat-title" style="-fx-font-size: 11px; -fx-text-fill: -fx-text-secondary-color; -fx-font-weight: bold;"/>
                                                    <Label fx:id="plannerEstFeedLabel" text="0.00 kg" styleClass="stat-value" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary-color;"/>
                                                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                        <Label text="Stock Status:" styleClass="form-label" style="-fx-font-size: 11px;"/>
                                                        <Label fx:id="plannerFeedSufficiencyLabel" text="Loading..." styleClass="status-capsule"/>
                                                    </HBox>
                                                </VBox>
                                                
                                                <!-- Water Estimate Card -->
                                                <VBox styleClass="estimator-badge-card" HBox.hgrow="ALWAYS" spacing="8.0" style="-fx-padding: 12px; -fx-border-color: -fx-input-border-color; -fx-border-width: 1px; -fx-border-radius: 8px; -fx-background-radius: 8px;">
                                                    <Label text="ESTIMATED WATER REQUIREMENT (30 DAYS)" styleClass="stat-title" style="-fx-font-size: 11px; -fx-text-fill: -fx-text-secondary-color; -fx-font-weight: bold;"/>
                                                    <Label fx:id="plannerEstWaterLabel" text="0.00 L" styleClass="stat-value" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -fx-text-primary-color;"/>
                                                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                        <Label text="Stock Status:" styleClass="form-label" style="-fx-font-size: 11px;"/>
                                                        <Label fx:id="plannerWaterSufficiencyLabel" text="Loading..." styleClass="status-capsule"/>
                                                    </HBox>
                                                </VBox>
                                            </children>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Log Monthly Data Form & Log Table Side-by-Side -->
                                    <GridPane hgap="20.0" vgap="20.0">
                                        <columnConstraints>
                                            <ColumnConstraints percentWidth="35.0"/>
                                            <ColumnConstraints percentWidth="65.0"/>
                                        </columnConstraints>
                                        <children>
                                            <!-- Log Month Form -->
                                            <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="0" alignment="TOP_LEFT">
                                                <Label text="Log Actual Monthly Usage" styleClass="card-title"/>
                                                <VBox spacing="14.0" VBox.vgrow="ALWAYS">
                                                    <VBox spacing="6.0">
                                                        <Label text="Actual Feed Consumed (kg)" styleClass="form-label"/>
                                                        <TextField fx:id="actualFeedField" styleClass="text-input-modern" promptText="e.g. 1500"/>
                                                    </VBox>
                                                    <VBox spacing="6.0">
                                                        <Label text="Actual Water Consumed (L)" styleClass="form-label"/>
                                                        <TextField fx:id="actualWaterField" styleClass="text-input-modern" promptText="e.g. 3500"/>
                                                    </VBox>
                                                    <Region VBox.vgrow="ALWAYS"/>
                                                    <Button text="Commit Monthly Log" onAction="#handleLogMonth" styleClass="button-primary" maxWidth="Infinity" prefHeight="40.0"/>
                                                </VBox>
                                            </VBox>
                                            
                                            <!-- History Table -->
                                            <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="1" minHeight="300.0" VBox.vgrow="ALWAYS">
                                                <Label text="Consumption Log History" styleClass="card-title"/>
                                                <TableView fx:id="monthlyLogsTable" VBox.vgrow="ALWAYS" minHeight="200.0">
                                                    <columns>
                                                        <TableColumn fx:id="logMonthCol" text="Month/Year" prefWidth="100.0"/>
                                                        <TableColumn fx:id="logFlockCol" text="Birds" prefWidth="80.0"/>
                                                        <TableColumn fx:id="logEstFeedCol" text="Est Feed (kg)" prefWidth="100.0"/>
                                                        <TableColumn fx:id="logEstWaterCol" text="Est Water (L)" prefWidth="100.0"/>
                                                        <TableColumn fx:id="logActFeedCol" text="Act Feed (kg)" prefWidth="100.0"/>
                                                        <TableColumn fx:id="logActWaterCol" text="Act Water (L)" prefWidth="100.0"/>
                                                    </columns>
                                                    <columnResizePolicy>
                                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                                    </columnResizePolicy>
                                                </TableView>
                                                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                                    <Button text="Delete Selected Log" onAction="#handleDeleteMonthlyLog" styleClass="button-danger" prefHeight="40.0" prefWidth="180.0"/>
                                                </HBox>
                                            </VBox>
                                        </children>
                                    </GridPane>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>

                <!-- Tab 3: Stock Analytics -->
                <Tab text="Stock Analytics" styleClass="modern-tab">
                    <content>
                        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-padding: 0;">
                            <content>
                                <VBox spacing="20.0" style="-fx-padding: 20px 8px 20px 0px;">
                                    <!-- Chart Card -->
                                    <VBox spacing="16.0" styleClass="content-card" minHeight="500.0" VBox.vgrow="ALWAYS">
                                        <Label text="Current Stock vs. Monthly Committed Quota" styleClass="card-title"/>
                                        <Label text="Visualizes actual inventory quantities compared to dynamically calculated monthly flock requirements. The horizontal red dashed line represents 100% adequacy of committed quota." styleClass="view-desc"/>
                                        <StackPane fx:id="analyticsStackPane" VBox.vgrow="ALWAYS">
                                            <children>
                                                <BarChart fx:id="stockBarChart" animated="false" legendVisible="false" prefHeight="400.0">
                                                    <xAxis>
                                                        <CategoryAxis fx:id="stockXAxis" label="Supply Type"/>
                                                    </xAxis>
                                                    <yAxis>
                                                        <NumberAxis fx:id="stockYAxis" label="Adequacy Level (%)" lowerBound="0.0" upperBound="120.0" autoRanging="false" tickUnit="20.0"/>
                                                    </yAxis>
                                                </BarChart>
                                            </children>
                                        </StackPane>
                                    </VBox>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </VBox>
</VBox>
