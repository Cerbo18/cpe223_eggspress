<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cpe223.group8.eggspress.controllers.InventoryController"
      prefHeight="600.0" prefWidth="800.0"
      styleClass="view-root-container">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
        <URL value="@../css/inventory/inventory.css" />
        <URL value="@../css/inventory/light.css" />
    </stylesheets>

    <VBox spacing="24.0" VBox.vgrow="ALWAYS" styleClass="view-content-pane">
        <padding>
            <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
        </padding>

        <VBox spacing="6.0">
            <Label text="Inventory Management" styleClass="view-title"/>
            <Label text="Track feed levels, water stock, supplements, and allocate resources across coops." styleClass="view-desc"/>
        </VBox>

        <!-- Inventory List Card -->
        <VBox spacing="16.0" styleClass="content-card" VBox.vgrow="ALWAYS">
            <Label text="Current Farm Inventory" styleClass="card-title"/>
            <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="80.0"/>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="220.0"/>
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120.0"/>
                    <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="120.0"/>
                    <TableColumn fx:id="unitColumn" text="Unit" prefWidth="120.0"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Grid of Controls -->
        <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="55.0"/>
                <ColumnConstraints percentWidth="45.0"/>
            </columnConstraints>
            <children>
                <!-- Add New Item Card -->
                <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="0">
                    <Label text="Create New Inventory Item" styleClass="card-title"/>
                    <GridPane hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50.0"/>
                            <ColumnConstraints percentWidth="50.0"/>
                        </columnConstraints>
                        <children>
                            <TextField fx:id="nameField" promptText="Item Name (e.g. Water Tank A)" styleClass="text-input-modern" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <ComboBox fx:id="categoryComboBox" promptText="Category" styleClass="combo-box-modern" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <TextField fx:id="quantityField" promptText="Initial Qty" styleClass="text-input-modern" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextField fx:id="unitField" promptText="Unit (e.g. Liters, kg)" styleClass="text-input-modern" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        </children>
                    </GridPane>
                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 4px 0px 0px 0px;">
                        <Button text="Add Item" onAction="#handleAddItem" styleClass="button-primary" prefHeight="40.0" prefWidth="120.0"/>
                    </HBox>
                </VBox>

                <!-- Stock Control Card -->
                <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="1">
                    <Label text="Selected Item Stock Control" styleClass="card-title"/>
                    <VBox spacing="12.0" VBox.vgrow="ALWAYS" alignment="CENTER_LEFT">
                        <Label text="Adjust quantity of the selected table item:" styleClass="form-label"/>
                        <TextField fx:id="adjustmentField" promptText="Adjustment Amount" styleClass="text-input-modern" maxWidth="Infinity"/>
                    </VBox>
                    <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-padding: 4px 0px 0px 0px;">
                        <Button text="Consume" onAction="#handleConsumeStock" styleClass="button-secondary" prefHeight="40.0" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Add Stock" onAction="#handleAddStock" styleClass="button-primary" prefHeight="40.0" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Delete" onAction="#handleDeleteItem" styleClass="button-danger" prefHeight="40.0" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                </VBox>
            </children>
        </GridPane>

    </VBox>
</VBox>


