                <VBox spacing="6.0" alignment="CENTER">
                    <Label text="Welcome Back" styleClass="welcome-title" />
                    <Label text="Sign in to your Eggspress account" styleClass="welcome-subtitle" />
                </VBox>

                <VBox alignment="TOP_CENTER" VBox.vgrow="ALWAYS" spacing="12.0">
                    <StackPane alignment="TOP_CENTER">
                        <VBox fx:id="usernameStep" spacing="8.0" alignment="TOP_CENTER">
                            <TextField fx:id="usernameField" promptText="Username" styleClass="text-input-modern" prefHeight="44.0" />
                        </VBox>
                        
                        <VBox fx:id="passwordStep" spacing="8.0" alignment="TOP_CENTER" visible="false" managed="false">
                            <HBox alignment="CENTER" spacing="4.0">
                                <Label text="Logging in as" styleClass="welcome-subtitle" />
                                <Label fx:id="userConfirmationLabel" text="admin" styleClass="welcome-subtitle" style="-fx-font-weight: bold; -fx-text-fill: -fx-brand-primary;" />
                            </HBox>
                            <PasswordField fx:id="passwordField" promptText="Password" styleClass="text-input-modern" prefHeight="44.0" />
                        </VBox>
                    </StackPane>

                    <HBox fx:id="errorContainer" alignment="CENTER_LEFT" spacing="6.0" visible="false" managed="false" style="-fx-padding: 2px 0px 0px 4px;">
                        <Label text="⚠" style="-fx-text-fill: #ff3b30; -fx-font-size: 14px; -fx-font-weight: bold;" />
                        <Label fx:id="messageLabel" styleClass="error-message" wrapText="true" />
                    </HBox>
                </VBox>

                <VBox alignment="BOTTOM_CENTER" spacing="0.0">
                    <StackPane alignment="BOTTOM_CENTER">
                        <VBox fx:id="usernameActions" alignment="BOTTOM_CENTER">
                            <Button text="Next" onAction="#handleNext" styleClass="button-primary" prefWidth="328.0" prefHeight="44.0" defaultButton="true" />
                        </VBox>
                        
                        <HBox fx:id="passwordActions" spacing="12.0" alignment="BOTTOM_CENTER" visible="false" managed="false">
                            <Button text="Back" onAction="#handleBack" styleClass="text-input-modern" style="-fx-cursor: hand; -fx-background-color: transparent;" prefWidth="80.0" prefHeight="44.0" />
                            <Button text="Login" onAction="#handleLogin" styleClass="button-primary" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="44.0" defaultButton="true" />
                        </HBox>
                    </StackPane>
                </VBox>
            </VBox>
        </VBox>

        <HBox styleClass="login-footer" prefHeight="50.0" alignment="CENTER_LEFT">
            <padding>
                <Insets top="0.0" right="48.0" bottom="0.0" left="48.0" />
            </padding>
            <Label text="Eggspress Chicken Farm Manager v0.0.1-pre-alpha.1" styleClass="welcome-subtitle" style="-fx-font-size: 11px;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Copyright © 2026. All rights reserved." styleClass="welcome-subtitle" style="-fx-font-size: 11px;" />
        </HBox>
    </VBox>

    <!-- Theme Toggle Floating Button -->
    <Button fx:id="themeToggleBtn" styleClass="sidebar-action-btn" onAction="#handleToggleTheme"
            StackPane.alignment="BOTTOM_RIGHT">
        <StackPane.margin>
            <Insets bottom="75.0" right="24.0" />
        </StackPane.margin>
        <graphic>
            <StackPane minWidth="24.0" prefWidth="24.0" minHeight="24.0" prefHeight="24.0" alignment="CENTER">
                <Group scaleX="0.8" scaleY="0.8">
                    <SVGPath fx:id="themeToggleIcon" styleClass="sidebar-toggle-icon" content="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454l0 .008" />
                </Group>
            </StackPane>
        </graphic>
    </Button>
</StackPane>
