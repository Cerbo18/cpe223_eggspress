<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cpe223.group8.eggspress.controllers.OverviewController" styleClass="view-root-container">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
        <URL value="@../css/overview/overview.css" />
        <URL value="@../css/overview/light.css" />
    </stylesheets>

    <VBox spacing="24.0" VBox.vgrow="ALWAYS" styleClass="overview-content-pane">
        <padding>
            <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
        </padding>

        <!-- Grid Title -->
        <Label text="Live Farm Metrics" styleClass="stat-grid-title" />

        <!-- Stats Row -->
        <HBox spacing="20.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
            <children>
                <!-- Card 1: Coops -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefWidth="180.0">
                    <children>
                        <Label text="ACTIVE COOPS" styleClass="stat-title" />
                        <Label fx:id="coopsStat" text="0 Coops" styleClass="stat-value" />
                        <Label fx:id="coopsIndicator" text="● Loading..." styleClass="stat-indicator" />
                    </children>
                </VBox>

                <!-- Card 2: Flock -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefWidth="180.0">
                    <children>
                        <Label text="TOTAL FLOCK" styleClass="stat-title" />
                        <Label fx:id="flockStat" text="0 Birds" styleClass="stat-value" />
                        <Label fx:id="flockIndicator" text="▲ Stable Stock" styleClass="stat-indicator" />
                    </children>
                </VBox>

                <!-- Card 3: Feed Stock -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefWidth="180.0">
                    <children>
                        <Label text="FEED STOCK" styleClass="stat-title" />
                        <Label fx:id="feedStat" text="0 kg" styleClass="stat-value" />
                        <Label fx:id="feedIndicator" text="● Loading..." styleClass="stat-indicator" />
                    </children>
                </VBox>

                <!-- Card 4: Water Stock -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefWidth="180.0">
                    <children>
                        <Label text="WATER STOCK" styleClass="stat-title" />
                        <Label fx:id="waterStat" text="0 L" styleClass="stat-value" />
                        <Label fx:id="waterIndicator" text="● Loading..." styleClass="stat-indicator" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Live Coops Table -->
        <VBox spacing="16.0" styleClass="content-card" VBox.vgrow="ALWAYS">
            <Label text="Active Farm Buildings &amp; Coops" styleClass="card-title" />
            <TableView fx:id="coopsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="coopIdCol" prefWidth="120.0" text="Coop ID" />
                    <TableColumn fx:id="coopNameCol" prefWidth="250.0" text="Building / Coop Name" />
                    <TableColumn fx:id="coopFlockCol" prefWidth="150.0" text="Flock Size (Birds)" />
                    <TableColumn fx:id="coopStatusCol" prefWidth="150.0" text="Operational Status" />
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </VBox>
</VBox>
