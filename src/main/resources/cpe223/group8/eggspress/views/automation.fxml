<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cpe223.group8.eggspress.controllers.AutomationController" styleClass="view-root-container">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
        <URL value="@../css/automation/automation.css" />
        <URL value="@../css/automation/light.css" />
    </stylesheets>

    <VBox spacing="24.0" VBox.vgrow="ALWAYS" styleClass="view-content-pane">
        <padding>
            <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
        </padding>

        <VBox spacing="6.0">
            <Label text="Automation &amp; Feeding Schedules" styleClass="view-title" />
            <Label text="Schedule chicken feeding sequences and dispatch automated hydration controls." styleClass="view-desc" />
        </VBox>

        <!-- Split into Columns or Cards -->
        <GridPane hgap="20.0" vgap="20.0" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints percentWidth="40.0"/>
                <ColumnConstraints percentWidth="60.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="100.0"/>
            </rowConstraints>
            <children>
                <!-- Hydration Dispatcher Card -->
                <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="0">
                    <Label text="Water Dispatch Automation" styleClass="card-title" />
                    <VBox spacing="16.0" VBox.vgrow="ALWAYS">
                        <VBox spacing="6.0">
                            <Label text="Water Source" styleClass="form-label" />
                            <ComboBox fx:id="waterSourceComboBox" maxWidth="Infinity" styleClass="combo-box-modern" promptText="Select Source"/>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label text="Location Target" styleClass="form-label" />
                            <ComboBox fx:id="locationComboBox" maxWidth="Infinity" styleClass="combo-box-modern" promptText="Select Destination"/>
                        </VBox>
                        <VBox spacing="6.0">
                            <Label text="Amount (Liters)" styleClass="form-label" />
                            <TextField fx:id="waterAmountField" styleClass="text-input-modern" promptText="e.g. 50"/>
                        </VBox>
                    </VBox>
                    <HBox alignment="BOTTOM_RIGHT" spacing="10.0" style="-fx-padding: 8px 0px 0px 0px;">
                        <Button onAction="#handleSendWater" text="Send Water" styleClass="button-primary" prefHeight="40.0" prefWidth="120.0" />
                    </HBox>
                </VBox>

                <!-- Feeding Schedule Board Card -->
                <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="1">
                    <Label text="Feeding Schedule Board" styleClass="card-title" />
                    <TableView fx:id="scheduleTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="categoryCol" prefWidth="120.0" text="Category" />
                            <TableColumn fx:id="timeCol" prefWidth="100.0" text="Time" />
                            <TableColumn fx:id="feedingTypeCol" prefWidth="180.0" text="Feeding Type" />
                            <TableColumn fx:id="statusCol" prefWidth="120.0" text="Status" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </children>
        </GridPane>

        <!-- Split bottom layout: Live Telemetry left, Add Schedule right -->
        <GridPane hgap="20.0" vgap="20.0">
            <columnConstraints>
                <ColumnConstraints percentWidth="50.0"/>
                <ColumnConstraints percentWidth="50.0"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints percentHeight="100.0"/>
            </rowConstraints>
            <children>
                <!-- Live Telemetry Card -->
                <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="0">
                    <Label text="Live Equipment &amp; Environmental Telemetry" styleClass="card-title" />
                    <TableView fx:id="telemetryTable" VBox.vgrow="ALWAYS" prefHeight="220.0">
                        <columns>
                            <TableColumn fx:id="telemetryCoopCol" prefWidth="130.0" text="Coop Location" />
                            <TableColumn fx:id="telemetryTempCol" prefWidth="85.0" text="Temp (°C)" />
                            <TableColumn fx:id="telemetryHumidCol" prefWidth="85.0" text="Humid (%)" />
                            <TableColumn fx:id="telemetryFanCol" prefWidth="120.0" text="Ventilation Fan" />
                            <TableColumn fx:id="telemetryMisterCol" prefWidth="95.0" text="Misters" />
                            <TableColumn fx:id="telemetryFeederCol" prefWidth="95.0" text="Feeders" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <!-- Add New Feeding Schedule Card -->
                <VBox spacing="16.0" styleClass="content-card" GridPane.columnIndex="1">
                    <Label text="Add New Feeding Schedule" styleClass="card-title" />
                    <GridPane hgap="12.0" vgap="12.0" VBox.vgrow="ALWAYS">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50.0"/>
                            <ColumnConstraints percentWidth="50.0"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints minHeight="50.0"/>
                            <RowConstraints minHeight="50.0"/>
                        </rowConstraints>
                        <children>
                            <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Category" styleClass="form-label" />
                                <ComboBox fx:id="scheduleCategoryComboBox" maxWidth="Infinity" styleClass="combo-box-modern" promptText="Select Category"/>
                            </VBox>
                            <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Time Trigger" styleClass="form-label" />
                                <TextField fx:id="scheduleTimeField" styleClass="text-input-modern" promptText="e.g. 08:00 AM" />
                            </VBox>
                            <VBox spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Action / Feeding Type" styleClass="form-label" />
                                <TextField fx:id="scheduleFeedingTypeField" styleClass="text-input-modern" promptText="e.g. High-Protein Mix" />
                            </VBox>
                            <VBox spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Initial Status" styleClass="form-label" />
                                <TextField fx:id="scheduleStatusField" styleClass="text-input-modern" promptText="e.g. Pending" />
                            </VBox>
                        </children>
                    </GridPane>
                    <HBox alignment="BOTTOM_RIGHT" spacing="10.0" style="-fx-padding: 8px 0px 0px 0px;">
                        <Button onAction="#handleCreateSchedule" text="Add Schedule" styleClass="button-primary" prefHeight="40.0" prefWidth="130.0" />
                        <Button onAction="#handleDeleteButton" text="Delete Selected" styleClass="button-danger" prefHeight="40.0" prefWidth="130.0" />
                    </HBox>
                </VBox>
            </children>
        </GridPane>

    </VBox>
</VBox>

