<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox prefWidth="480.0" prefHeight="540.0" spacing="20.0" 
      alignment="TOP_CENTER" styleClass="content-card"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="cpe223.group8.eggspress.controllers.SettingsController">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
    </stylesheets>
    
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label text="Application Settings" styleClass="view-title" style="-fx-font-size: 20px;" />
            <Label text="Configure behavior and manage database state." styleClass="view-desc" />
        </VBox>
    </HBox>

    <VBox spacing="16.0" VBox.vgrow="ALWAYS">
        <!-- 1. Theme Configuration -->
        <VBox spacing="6.0">
            <Label text="Default Starting Theme" styleClass="form-label" />
            <ComboBox fx:id="themeSelector" styleClass="combo-box-modern" maxWidth="Infinity" />
        </VBox>

        <!-- 2. Notification Preferences -->
        <VBox spacing="8.0">
            <Label text="Notification Alerts" styleClass="form-label" />
            <CheckBox fx:id="enableToastsCheckbox" text="Enable Real-Time Push Toast Alerts" 
                      styleClass="welcome-subtitle" style="-fx-font-size: 13px;" />
            <VBox spacing="6.0">
                <Label text="Toast Severity Filter" styleClass="form-label" style="-fx-opacity: 0.8;" />
                <ComboBox fx:id="severityFilterSelector" styleClass="combo-box-modern" maxWidth="Infinity" />
            </VBox>
        </VBox>

        <!-- 3. Developer Mode -->
        <VBox spacing="6.0">
            <Label text="Developer Options" styleClass="form-label" />
            <CheckBox fx:id="developerModeCheckbox" text="Enable Developer Mode &amp; Diagnostics Panel" 
                      styleClass="welcome-subtitle" style="-fx-font-size: 13px;" />
        </VBox>

        <!-- 4. Database Setup -->
        <VBox spacing="8.0" style="-fx-border-color: -fx-input-border-color; -fx-border-width: 1px 0 0 0; -fx-padding: 12px 0 0 0;">
            <Label text="Database Configurations" styleClass="form-label" />
            <VBox spacing="4.0">
                <Label text="Active SQLite Database Location:" styleClass="welcome-subtitle" style="-fx-font-size: 11px;" />
                <TextField fx:id="dbPathField" editable="false" styleClass="text-input-modern" style="-fx-font-size: 12px; -fx-padding: 8px 12px;" />
            </VBox>
            <HBox spacing="12.0" style="-fx-padding: 4px 0 0 0;">
                <Button fx:id="testConnectionBtn" text="Test Connection" onAction="#handleTestConnection" styleClass="button-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                <Button fx:id="resetDbBtn" text="Reset Tables" onAction="#handleResetDatabase" styleClass="button-danger" />
            </HBox>
            <Label fx:id="statusLabel" wrapText="true" styleClass="feedback-message" visible="false" style="-fx-font-size: 12px;" />
        </VBox>
    </VBox>

    <!-- Footer buttons -->
    <HBox spacing="12.0" alignment="BOTTOM_RIGHT" style="-fx-padding: 8px 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel" styleClass="button-secondary" prefWidth="100.0" />
        <Button text="Save Preferences" onAction="#handleSave" styleClass="button-primary" prefWidth="160.0" />
    </HBox>
</VBox>
