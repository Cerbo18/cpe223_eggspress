<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<VBox prefWidth="420.0" prefHeight="280.0" spacing="16.0" 
      alignment="TOP_CENTER" styleClass="content-card"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="cpe223.group8.eggspress.controllers.AdjustStockModalController">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
        <URL value="@../css/inventory/inventory.css" />
        <URL value="@../css/inventory/light.css" />
    </stylesheets>
    
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <!-- Header Section -->
    <VBox spacing="4.0" alignment="TOP_LEFT" maxWidth="Infinity">
        <Label text="Adjust Stock Quantity" styleClass="view-title" style="-fx-font-size: 18px;" />
        <Label fx:id="itemDetailsLabel" text="Selected Item: Loading..." styleClass="view-desc" style="-fx-text-fill: -fx-text-primary-color; -fx-font-weight: bold;" />
    </VBox>

    <!-- Form Body -->
    <VBox spacing="12.0" VBox.vgrow="ALWAYS">
        <VBox spacing="6.0">
            <Label text="Adjustment Quantity" styleClass="form-label" />
            <TextField fx:id="adjustmentField" promptText="Enter amount (e.g. 50)" styleClass="text-input-modern" maxWidth="Infinity" />
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Action Buttons -->
    <HBox spacing="10.0" alignment="BOTTOM_RIGHT" maxWidth="Infinity">
        <Button text="Cancel" onAction="#handleCancel" styleClass="button-secondary" prefWidth="90.0" prefHeight="38.0" />
        <Button text="Consume" onAction="#handleConsume" styleClass="button-danger" prefWidth="110.0" prefHeight="38.0" />
        <Button text="Add Stock" onAction="#handleAddStock" styleClass="button-primary" prefWidth="120.0" prefHeight="38.0" />
    </HBox>
</VBox>
