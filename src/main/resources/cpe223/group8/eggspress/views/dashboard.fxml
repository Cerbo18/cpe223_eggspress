<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HeaderBar?>

<VBox prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cpe223.group8.eggspress.controllers.DashboardController">
    <HeaderBar styleClass="app-headerbar" />

    <VBox alignment="CENTER" spacing="15.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>

        <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="welcome to dashboard" />
        
        <Button onAction="#handleAccountManagement" text="Account Management" />
        
        <Button onAction="#handleInventoryManagement" text="Inventory Management" />
        
        <Button onAction="#handleAutomationManagement" text="Automation &amp; Schedules" />
        <Button mnemonicParsing="false" onAction="#handleViewLayout" text="View Layout" />
        
        <Button onAction="#handleLogout" text="Logout" />
    </VBox>
</VBox>
