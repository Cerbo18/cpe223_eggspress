<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cpe223.group8.eggspress.controllers.AcountMgmtController"
      prefHeight="600.0" prefWidth="800.0"
      styleClass="view-root-container">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
        <URL value="@../css/acountMgmt/acountMgmt.css" />
        <URL value="@../css/acountMgmt/light.css" />
    </stylesheets>

    <VBox spacing="24.0" VBox.vgrow="ALWAYS" styleClass="view-content-pane">
        <padding>
            <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
        </padding>

        <VBox spacing="6.0">
            <Label text="Account Management" styleClass="view-title"/>
            <Label text="Manage and create user credentials for the Eggspress Chicken Farm Management platform." styleClass="view-desc"/>
        </VBox>

        <VBox spacing="16.0" styleClass="content-card" VBox.vgrow="ALWAYS">
            <Label text="System Accounts" styleClass="card-title"/>
            <TableView fx:id="accountsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="usernameColumn" text="Username" prefWidth="250.0"/>
                    <TableColumn fx:id="passwordColumn" text="Password" prefWidth="250.0"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <VBox spacing="16.0" styleClass="content-card">
            <Label text="Create New Account" styleClass="card-title"/>
            <HBox spacing="12.0" alignment="CENTER_LEFT">
                <TextField fx:id="newUsernameField" promptText="New Username" styleClass="text-input-modern" HBox.hgrow="ALWAYS"/>
                <TextField fx:id="newPasswordField" promptText="New Password" styleClass="text-input-modern" HBox.hgrow="ALWAYS"/>
                <Button text="Create Account" onAction="#handleCreateAccount" styleClass="button-primary" prefHeight="44.0"/>
            </HBox>
        </VBox>

    </VBox>
</VBox>

