<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="cpe223.group8.eggspress.controllers.AccountMgmtController"
      prefHeight="600.0" prefWidth="800.0"
      styleClass="view-root-container">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/light.css" />
        <URL value="@../css/acountMgmt/acountMgmt.css" />
        <URL value="@../css/acountMgmt/light.css" />
    </stylesheets>

    <VBox spacing="24.0" VBox.vgrow="ALWAYS" styleClass="view-content-pane">
        <padding>
            <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
        </padding>

        <!-- Header containing Title area and Top-Right Create button -->
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Account Management" styleClass="view-title"/>
            </VBox>
            <Button text="Create Account" onAction="#handleShowCreatePopup" styleClass="button-primary" prefHeight="40.0"/>
        </HBox>

        <!-- Table displaying registered accounts and actions -->
        <VBox spacing="16.0" styleClass="content-card" VBox.vgrow="ALWAYS">
            <Label text="System Accounts" styleClass="card-title"/>
            <TableView fx:id="accountsTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="usernameColumn" text="NAME" prefWidth="180.0"/>
                    <TableColumn fx:id="passwordColumn" text="PASS" prefWidth="240.0"/>
                    <TableColumn fx:id="roleColumn" text="ROLE" prefWidth="130.0"/>
                    <TableColumn fx:id="actionColumn" text="ACTION" prefWidth="130.0" styleClass="centered-column"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

    </VBox>
</VBox>
