<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.eggspress.controllers.AutomationController"
      spacing="15.0"
      prefHeight="600.0" prefWidth="800.0">

    <padding>
        <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
    </padding>

    <!-- Navigation Header -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button text="Back to Dashboard" onAction="#handleBackToDashboard"/>
        <Label text="Automation &amp; Feeding Schedules" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    </HBox>

    <Label text="Water Dispatch Automation" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Water Source:"/>
            <ComboBox fx:id="waterSourceComboBox" prefWidth="180.0"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text="Location:"/>
            <ComboBox fx:id="locationComboBox" prefWidth="150.0"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text="Amount (Liters):"/>
            <TextField fx:id="waterAmountField" prefWidth="100.0"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text=""/>
            <Button text="Send Water" onAction="#handleSendWater"/>
        </VBox>
    </HBox>
    
    <Label fx:id="waterFeedbackLabel" style="-fx-text-fill: green;"/>

    <Label text="Feeding Schedule Board" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    
    <TableView fx:id="scheduleTable" prefHeight="200.0">
        <columns>
            <TableColumn fx:id="categoryCol" text="Category" prefWidth="150.0"/>
            <TableColumn fx:id="timeCol" text="Time" prefWidth="120.0"/>
            <TableColumn fx:id="feedingTypeCol" text="Feeding Type" prefWidth="250.0"/>
            <TableColumn fx:id="statusCol" text="Status" prefWidth="150.0"/>
        </columns>
    </TableView>

    <Label text="Add New Feeding Schedule" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label text="Category:"/>
            <ComboBox fx:id="scheduleCategoryComboBox" prefWidth="120.0"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text="Time:"/>
            <TextField fx:id="scheduleTimeField" promptText="e.g. 08:00 AM" prefWidth="100.0"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text="Feeding Type:"/>
            <TextField fx:id="scheduleFeedingTypeField" promptText="e.g. Layer Feed" prefWidth="180.0"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text="Status:"/>
            <TextField fx:id="scheduleStatusField" promptText="e.g. Scheduled" prefWidth="120.0"/>
        </VBox>
        <VBox spacing="5.0">
            <Label text=""/>
            <Button text="Add Schedule" onAction="#handleCreateSchedule"/>
        </VBox>
    </HBox>
    
    <Label fx:id="scheduleFeedbackLabel" style="-fx-text-fill: green;"/>

</VBox>
